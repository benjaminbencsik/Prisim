# Kalshi API credentials (never commit real values)
KALSHI_API_KEY_ID=your-key-id
KALSHI_PRIVATE_KEY_PATH=/absolute/path/to/kalshi-private-key.pem

# Use "demo" for paper trading or "prod" for live Kalshi.
KALSHI_ENV=demo

# Prism defaults
PRISM_DRY_RUN=true
PRISM_TIMEOUT=20
PRISM_DATABASE=prism.db
PRISM_MAX_ORDER_COST_CENTS=10000
PRISM_MAX_OPEN_ORDERS=20
PRISM_KILL_SWITCH=false
